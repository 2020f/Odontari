@model IEnumerable<OrdenCobroListViewModel>
@{
    ViewData["Title"] = "Caja";
}

<div class="content-header">
    <h1>Caja — Pendientes de cobro</h1>
    <div class="d-flex gap-2">
        <a asp-action="HistorialPagos" class="btn-content-secondary">Historial de pagos</a>
    </div>
</div>
@if (TempData["CajaMsg"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["CajaMsg"]
        @if (TempData["FacturaId"] is int fid)
        {
            <a asp-action="DescargarFacturaPdf" asp-route-id="@fid" class="alert-link ms-2" target="_blank" rel="noopener">Descargar factura (PDF)</a>
        }
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}
<div class="content-card">
    <table class="table">
        <thead>
            <tr>
                <th>Paciente</th>
                <th>Total</th>
                <th>Pagado</th>
                <th>Saldo</th>
                <th>Fecha</th>
                <th>Factura</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td>@o.PacienteNombre</td>
                    <td>RD$ @o.Total.ToString("N2")</td>
                    <td>RD$ @o.MontoPagado.ToString("N2")</td>
                    <td>RD$ @o.SaldoPendiente.ToString("N2")</td>
                    <td>@o.CreadoAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        @if (o.FacturaId.HasValue)
                        {
                            <a asp-action="DescargarFacturaPdf" asp-route-id="@o.FacturaId" class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener">Descargar factura</a>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td><a asp-action="Cobrar" asp-route-id="@o.Id" class="btn btn-primary btn-sm">Cobrar</a></td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Any()) { <div class="content-empty">No hay órdenes pendientes de cobro.</div> }
</div>
