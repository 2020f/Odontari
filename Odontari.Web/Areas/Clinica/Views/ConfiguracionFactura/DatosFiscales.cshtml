@model Odontari.Web.ViewModels.DatosFiscalesViewModel
@{
    ViewData["Title"] = "Datos fiscales de la clínica";
}
<div class="content-card">
    <h1 class="mb-3">Datos fiscales (emisor)</h1>
    <p class="text-muted">Información legal que aparecerá en cada factura. Debe coincidir con el registro en DGII.</p>

    @if (TempData["ConfigFacturaMsg"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["ConfigFacturaMsg"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    }

    <form asp-action="DatosFiscales" method="post" class="mb-0">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label asp-for="RazonSocial" class="form-label">Nombre o Razón Social (DGII)</label>
            <input asp-for="RazonSocial" class="form-control" placeholder="Razón social registrada en DGII" />
            <span asp-validation-for="RazonSocial" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="RNC" class="form-label">RNC</label>
            <input asp-for="RNC" class="form-control" placeholder="Ej: 1-31-12345-6" maxlength="20" />
            <span asp-validation-for="RNC" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="NombreComercial" class="form-label">Nombre comercial (opcional)</label>
            <input asp-for="NombreComercial" class="form-control" placeholder="Nombre con el que opera la clínica" />
        </div>
        <div class="mb-3">
            <label asp-for="DireccionFiscal" class="form-label">Dirección fiscal completa</label>
            <input asp-for="DireccionFiscal" class="form-control" placeholder="Dirección registrada en DGII" />
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Telefono" class="form-label">Teléfono principal</label>
                <input asp-for="Telefono" class="form-control" type="tel" />
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Email" class="form-label">Correo electrónico oficial</label>
                <input asp-for="Email" class="form-control" type="email" />
            </div>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Guardar datos fiscales</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
        </div>
    </form>
</div>
