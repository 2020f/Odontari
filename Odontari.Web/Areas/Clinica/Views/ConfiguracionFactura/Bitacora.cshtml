@{
    ViewData["Title"] = "Bitácora NCF";
    var lista = ViewBag.Lista as List<Odontari.Web.ViewModels.NCFBitacoraItemViewModel> ?? new List<Odontari.Web.ViewModels.NCFBitacoraItemViewModel>();
    var pagina = (int)(ViewBag.Pagina ?? 1);
    var totalPaginas = (int)(ViewBag.TotalPaginas ?? 0);
    var total = (int)(ViewBag.Total ?? 0);
    var filtroNcf = ViewBag.FiltroNcf as string;
    var filtroFacturaId = ViewBag.FiltroFacturaId as int?;
    var filtroDesde = ViewBag.FiltroDesde as DateTime?;
    var filtroHasta = ViewBag.FiltroHasta as DateTime?;
}
<div class="content-card">
    <h1 class="mb-3">Bitácora NCF</h1>
    <p class="text-muted">Auditoría de NCF usados: quién, cuándo, en qué factura.</p>

    <form method="get" asp-action="Bitacora" class="row g-2 mb-4">
        <div class="col-auto">
            <input type="text" name="ncf" value="@filtroNcf" class="form-control form-control-sm" placeholder="Buscar NCF" />
        </div>
        <div class="col-auto">
            <input type="number" name="facturaId" value="@filtroFacturaId" class="form-control form-control-sm" placeholder="ID Factura" />
        </div>
        <div class="col-auto">
            <input type="date" name="desde" value="@(filtroDesde?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" placeholder="Desde" />
        </div>
        <div class="col-auto">
            <input type="date" name="hasta" value="@(filtroHasta?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" placeholder="Hasta" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary btn-sm">Filtrar</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle table-sm">
            <thead>
                <tr>
                    <th>NCF</th>
                    <th>Tipo</th>
                    <th>Factura</th>
                    <th>Estado</th>
                    <th>Fecha/Hora</th>
                    <th>Usuario</th>
                    <th>Motivo</th>
                </tr>
            </thead>
            <tbody>
                @if (lista.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">No hay registros con los filtros aplicados.</td>
                    </tr>
                }
                @foreach (var m in lista)
                {
                    <tr>
                        <td><code>@m.NCFGenerado</code></td>
                        <td>@(m.TipoCodigo ?? "—")</td>
                        <td>@(m.FacturaId?.ToString() ?? "—")</td>
                        <td><span class="badge bg-secondary">@m.Estado</span></td>
                        <td>@m.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@(m.UsuarioNombre ?? "—")</td>
                        <td class="small">@(m.Motivo ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPaginas > 1)
    {
        <nav class="mt-2">
            <span class="me-2">Total: @total registros.</span>
            @if (pagina > 1)
            {
                <a asp-action="Bitacora" asp-route-pagina="@(pagina - 1)" asp-route-ncf="@filtroNcf" asp-route-facturaId="@filtroFacturaId" asp-route-desde="@(filtroDesde?.ToString("yyyy-MM-dd"))" asp-route-hasta="@(filtroHasta?.ToString("yyyy-MM-dd"))" class="btn btn-sm btn-outline-secondary">Anterior</a>
            }
            <span class="mx-2">Página @pagina de @totalPaginas</span>
            @if (pagina < totalPaginas)
            {
                <a asp-action="Bitacora" asp-route-pagina="@(pagina + 1)" asp-route-ncf="@filtroNcf" asp-route-facturaId="@filtroFacturaId" asp-route-desde="@(filtroDesde?.ToString("yyyy-MM-dd"))" asp-route-hasta="@(filtroHasta?.ToString("yyyy-MM-dd"))" class="btn btn-sm btn-outline-secondary">Siguiente</a>
            }
        </nav>
    }

    <div class="mt-3">
        <a asp-action="NCFRangos" class="btn btn-outline-secondary btn-sm">Ver rangos</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Volver</a>
    </div>
</div>
